datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  kasir
  admin_gudang
  owner
}

enum TypeMovement {
  restock
  usage
  adjustment
}

enum TransactionStatus {
  pending
  completed
  cancelled
}

enum PaymentMethod {
  cash
  non_cash
}

model User {
  id           String                   @id @default(uuid())
  name         String                   @db.VarChar(100)
  role         Role                     @default(owner)
  passwordHash String                   @map("password_hash")
  createdAt    DateTime                 @default(now()) @map("created_at")
  
  // Relations
  transactions           Transaction[]
  ingredientPrices       IngredientPriceHistory[]
  stockMovements         StockMovement[]

  @@map("users")
}

model Menu {
  id           String            @id @default(uuid())
  name         String            @db.VarChar(150)
  category     String            @db.VarChar(50) // e.g., Makanan, Minuman, Snack
  sellingPrice Decimal           @map("selling_price") @db.Decimal(12, 2)
  hpp          Decimal           @default(0) @map("hpp") @db.Decimal(12, 2)
  isAvailable  Boolean           @default(true) @map("is_available")
  imageUrl     String?           @map("image_url")
  createdAt    DateTime          @default(now()) @map("created_at")

  // Relations
  recipes      RecipeItem[]
  transItems   TransactionItem[]

  @@map("menus")
}

model Ingredient {
  id             String                   @id @default(uuid())
  name           String                   @db.VarChar(150)
  unit           String                   @db.VarChar(20) // e.g., gram, ml, pcs
  stockQty       Decimal                  @map("stock_qty") @db.Decimal(12, 3)
  minStockQty    Decimal                  @map("min_stock_qty") @db.Decimal(12, 3)
  latestPrice    Decimal                  @map("latest_price") @db.Decimal(12, 2)
  createdAt      DateTime                 @default(now()) @map("created_at")

  // Relations
  recipes        RecipeItem[]
  priceHistory   IngredientPriceHistory[]
  stockMovements StockMovement[]

  @@map("ingredients")
}

model RecipeItem {
  id           String     @id @default(uuid())
  menuId       String     @map("menu_id")
  ingredientId String     @map("ingredient_id")
  qtyUsed      Decimal    @map("qty_used") @db.Decimal(12, 3)

  // Relations
  menu         Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([menuId, ingredientId])
  @@map("recipe_items")
}

model IngredientPriceHistory {
  id           String     @id @default(uuid())
  ingredientId String     @map("ingredient_id")
  price        Decimal    @db.Decimal(12, 2)
  recordedAt   DateTime   @map("recorded_at") @db.Date
  recordedBy   String     @map("recorded_by")

  // Relations
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [recordedBy], references: [id])

  @@map("ingredient_price_history")
}

model StockMovement {
  id           String       @id @default(uuid())
  ingredientId String       @map("ingredient_id")
  type         TypeMovement
  qtyChange    Decimal      @map("qty_change") @db.Decimal(12, 3)
  note         String?
  createdAt    DateTime     @default(now()) @map("created_at")
  createdBy    String       @map("created_by")

  // Relations
  ingredient   Ingredient   @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [createdBy], references: [id])

  @@map("stock_movements")
}

model Transaction {
  id            String            @id @default(uuid())
  status        TransactionStatus @default(pending)
  paymentMethod PaymentMethod     @map("payment_method")
  totalPrice    Decimal           @map("total_price") @db.Decimal(12, 2)
  totalHpp      Decimal           @map("total_hpp") @db.Decimal(12, 2)
  cashierId     String            @map("cashier_id")
  createdAt     DateTime          @default(now()) @map("created_at")
  completedAt   DateTime?         @map("completed_at")

  // Relations
  user          User              @relation(fields: [cashierId], references: [id])
  items         TransactionItem[]

  @@map("transactions")
}

model TransactionItem {
  id            String      @id @default(uuid())
  transactionId String      @map("transaction_id")
  menuId        String      @map("menu_id")
  menuName      String      @map("menu_name") @db.VarChar(150)
  qty           Int
  unitPrice     Decimal     @map("unit_price") @db.Decimal(12, 2)
  unitHpp       Decimal     @map("unit_hpp") @db.Decimal(12, 2)

  // Relations
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  menu          Menu        @relation(fields: [menuId], references: [id])

  @@map("transaction_items")
}
