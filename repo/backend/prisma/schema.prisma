generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum UserRole {
  kasir
  admin_gudang
  owner
}

enum MovementType {
  restock
  usage
  adjustment
}

enum TransactionStatus {
  pending
  completed
  cancelled
}

enum PaymentMethod {
  cash
  non_cash
}

// ── Models ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid()) @db.Uuid
  name          String    @db.VarChar(100)
  role          UserRole
  password_hash String
  created_at    DateTime  @default(now()) @db.Timestamptz()

  transactions           Transaction[]
  stock_movements        StockMovement[]
  ingredient_price_logs  IngredientPriceHistory[]

  @@map("users")
}

model Menu {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(150)
  category      String   @db.VarChar(50)
  selling_price Decimal  @db.Decimal(12, 2)
  hpp           Decimal  @default(0) @db.Decimal(12, 2)
  is_available  Boolean  @default(true)
  image_url     String?
  created_at    DateTime @default(now()) @db.Timestamptz()

  recipe_items      RecipeItem[]
  transaction_items TransactionItem[]

  @@map("menus")
}

model Ingredient {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(150)
  unit          String   @db.VarChar(20)
  stock_qty     Decimal  @default(0) @db.Decimal(12, 3)
  min_stock_qty Decimal  @default(0) @db.Decimal(12, 3)
  latest_price  Decimal  @default(0) @db.Decimal(12, 2)
  created_at    DateTime @default(now()) @db.Timestamptz()

  recipe_items  RecipeItem[]
  price_history IngredientPriceHistory[]
  stock_movements StockMovement[]

  @@map("ingredients")
}

model RecipeItem {
  id            String     @id @default(uuid()) @db.Uuid
  menu_id       String     @db.Uuid
  ingredient_id String     @db.Uuid
  qty_used      Decimal    @db.Decimal(12, 3)

  menu       Menu       @relation(fields: [menu_id], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredient_id], references: [id])

  @@map("recipe_items")
}

model IngredientPriceHistory {
  id            String     @id @default(uuid()) @db.Uuid
  ingredient_id String     @db.Uuid
  price         Decimal    @db.Decimal(12, 2)
  recorded_at   DateTime   @db.Date
  recorded_by   String     @db.Uuid

  ingredient Ingredient @relation(fields: [ingredient_id], references: [id])
  user       User       @relation(fields: [recorded_by], references: [id])

  @@map("ingredient_price_history")
}

model StockMovement {
  id            String       @id @default(uuid()) @db.Uuid
  ingredient_id String       @db.Uuid
  type          MovementType
  qty_change    Decimal      @db.Decimal(12, 3)
  note          String?
  created_at    DateTime     @default(now()) @db.Timestamptz()
  created_by    String       @db.Uuid

  ingredient Ingredient @relation(fields: [ingredient_id], references: [id])
  user       User       @relation(fields: [created_by], references: [id])

  @@map("stock_movements")
}

model Transaction {
  id             String            @id @default(uuid()) @db.Uuid
  status         TransactionStatus @default(pending)
  payment_method PaymentMethod
  total_price    Decimal           @default(0) @db.Decimal(12, 2)
  total_hpp      Decimal           @default(0) @db.Decimal(12, 2)
  cashier_id     String            @db.Uuid
  created_at     DateTime          @default(now()) @db.Timestamptz()
  completed_at   DateTime?         @db.Timestamptz()

  cashier           User              @relation(fields: [cashier_id], references: [id])
  transaction_items TransactionItem[]

  @@map("transactions")
}

model TransactionItem {
  id             String  @id @default(uuid()) @db.Uuid
  transaction_id String  @db.Uuid
  menu_id        String  @db.Uuid
  menu_name      String  @db.VarChar(150)
  qty            Int
  unit_price     Decimal @db.Decimal(12, 2)
  unit_hpp       Decimal @db.Decimal(12, 2)

  transaction Transaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  menu        Menu        @relation(fields: [menu_id], references: [id])

  @@map("transaction_items")
}
