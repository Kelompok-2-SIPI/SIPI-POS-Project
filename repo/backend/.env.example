# Salin ke .env — jangan commit file .env

# Database — gunakan nama service Docker sebagai host (bukan localhost)
DATABASE_URL="postgresql://sipi_user:sipi_password@database:5432/sipi_db"

# JWT — WAJIB diisi, aplikasi akan gagal start (fail-fast) kalau kosong/tidak di-set.
# TIDAK ADA fallback default demi keamanan — jangan pernah commit nilai asli ke git.
# Generate nilai acak, misal: openssl rand -base64 48
JWT_SECRET="ganti_dengan_random_string_minimal_32_karakter"

# Server
PORT=4000
NODE_ENV=development

# CORS — origin frontend
FRONTEND_URL="http://localhost:3000"

# Gemini AI Chatbot
GEMINI_API_KEY=your_gemini_api_key_here
ENABLE_AI_CHAT=true

