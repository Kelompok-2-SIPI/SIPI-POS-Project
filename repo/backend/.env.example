# Salin file ini ke .env dan isi nilai yang sesuai
# JANGAN commit file .env ke repository

# Database — gunakan nama service Docker sebagai host (bukan localhost)
DATABASE_URL="postgresql://sipi:sipi_secret_ganti_ini@database:5432/sipi_pos"

# JWT
JWT_SECRET="ganti_dengan_string_random_minimal_32_karakter"

# Server
PORT=4000
NODE_ENV=development

# CORS — origin frontend (sesuaikan jika pakai custom domain)
FRONTEND_URL="http://localhost:3000"
